<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_DIR" value="logs" />
    <property name="LOG_NAME" value="gameroster" />

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty name="LOG_PATH" source="logging.file" defaultValue="logs" />

    <!-- ===================== -->
    <!-- CONSOLE APPENDER FIX -->
    <!-- ===================== -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">

        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>
                %white(%d{ISO8601}) %highlight(%-5level) [%blue(%thread)] %-60.60yellow(%logger{20}) : %msg%n%throwable
            </pattern>
        </encoder>

    </appender>

    <!-- ===================== -->
    <!-- FILE APPENDER -->
    <!-- ===================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${LOG_DIR}/${LOG_NAME}.log</file>

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36}.%M - %msg%n
            </pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${LOG_NAME}_%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>

    </appender>

    <!-- ===================== -->
    <!-- ROOT LOG LEVEL -->
    <!-- ===================== -->
    <root level="INFO">
        <appender-ref ref="FILE"/>
        <appender-ref ref="Console"/>
    </root>

</configuration>